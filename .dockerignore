# Keep the devcontainer build context small and prevent host build artifacts
# from leaking into the image. Container builds use the workspace-local
# CARGO_TARGET_DIR=/workspace/batpak/bpk-lib/target (set in devcontainer.json),
# so repo-root and nested target/ trees are host-only sprawl and must never cross.

target/
**/target/

# Git metadata is large and not needed inside the image.
.git/
.gitignore

# Host-specific coverage / bench / cache trees.
.artifacts/
.integrity-cache/
.cache/

# Editor / IDE / tool state.
.claude/
.codex/
.idea/
.vscode/
*.swp
*.swo

# Mutation-testing output.
mutants*/

# Local secrets.
.env
.env.local

# OS noise.
.DS_Store
