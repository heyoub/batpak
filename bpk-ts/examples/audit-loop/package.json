{
  "name": "@batpak/example-audit-loop",
  "version": "0.0.0",
  "private": true,
  "description": "Living loop: commit domain events, rebuild view from event.query + event.get.",
  "type": "module",
  "scripts": {
    "build": "tsc -b",
    "test": "vitest run --root .",
    "start": "node ./dist/index.js",
    "clean": "node -e \"for (const p of ['dist','tsconfig.tsbuildinfo']) require('node:fs').rmSync(p,{recursive:true,force:true})\""
  },
  "dependencies": {
    "@batpak/canonical": "workspace:*",
    "@batpak/client": "workspace:*",
    "@batpak/generated": "workspace:*",
    "@batpak/schema": "workspace:*"
  },
  "devDependencies": {
    "vitest": "2.1.9"
  }
}
