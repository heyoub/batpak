{
  "name": "@batpak/client",
  "version": "0.8.3",
  "description": "NETBAT/1 frame client. Phase 0: TCP only.",
  "license": "MIT OR Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/heyoub/batpak.git",
    "directory": "bpk-ts/packages/client"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "test": "vitest run --root .",
    "clean": "node -e \"for (const p of ['dist','tsconfig.tsbuildinfo']) require('node:fs').rmSync(p,{recursive:true,force:true})\""
  },
  "dependencies": {
    "@batpak/canonical": "workspace:*"
  }
}
