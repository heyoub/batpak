{
  "name": "@batpak/sdk",
  "version": "0.8.0",
  "description": "One-install BatPAK TypeScript SDK: NETBAT/1 client, canonical codec, Effect schema bridge, and manifest-generated types.",
  "license": "MIT OR Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/heyoub/batpak.git",
    "directory": "bpk-ts/packages/sdk"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "test": "vitest run --root .",
    "clean": "node -e \"for (const p of ['dist','tsconfig.tsbuildinfo']) require('node:fs').rmSync(p,{recursive:true,force:true})\""
  },
  "dependencies": {
    "@batpak/canonical": "workspace:*",
    "@batpak/client": "workspace:*",
    "@batpak/generated": "workspace:*",
    "@batpak/schema": "workspace:*"
  }
}
