{
  "name": "@batpak/schema",
  "version": "0.7.6",
  "private": true,
  "description": "Effect 4 Schema bridge for the BatPAK canonical wire. Runtime parse/encode + bank.event() authoring API.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "test": "vitest run --root .",
    "clean": "node -e \"for (const p of ['dist','tsconfig.tsbuildinfo']) require('node:fs').rmSync(p,{recursive:true,force:true})\""
  },
  "dependencies": {
    "effect": "4.0.0-beta.70",
    "@batpak/canonical": "workspace:*"
  }
}
