{
  "name": "@batpak/generated",
  "version": "0.8.1",
  "description": "Auto-generated bindings from batpak.manifest.json. FULLY OVERWRITTEN on each pnpm generate.",
  "license": "MIT OR Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/heyoub/batpak.git",
    "directory": "bpk-ts/packages/generated"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "src"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "test": "echo 'no tests'",
    "clean": "node -e \"for (const p of ['dist','tsconfig.tsbuildinfo']) require('node:fs').rmSync(p,{recursive:true,force:true})\""
  },
  "dependencies": {
    "effect": "4.0.0-beta.78"
  }
}
