{
  "name": "@batpak/canonical",
  "version": "0.8.2",
  "description": "Canonical named-field MessagePack codec matching rmp-serde 1.3.1, plus hex helpers for NETBAT framing.",
  "license": "MIT OR Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/heyoub/batpak.git",
    "directory": "bpk-ts/packages/canonical"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "test": "vitest run --root .",
    "clean": "node -e \"for (const p of ['dist','tsconfig.tsbuildinfo']) require('node:fs').rmSync(p,{recursive:true,force:true})\""
  },
  "devDependencies": {
    "fast-check": "4.8.0"
  }
}
