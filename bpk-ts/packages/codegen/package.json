{
  "name": "@batpak/codegen",
  "version": "0.0.0",
  "private": true,
  "description": "Generate TS bindings from a batpak.manifest.json.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "batpak-codegen": "./bin/batpak-codegen.js"
  },
  "scripts": {
    "build": "tsc -b",
    "test": "vitest run --root .",
    "generate": "tsc -b --force && node ./bin/batpak-codegen.js --manifest ../../batpak.manifest.json --out ../generated/src",
    "clean": "node -e \"for (const p of ['dist','tsconfig.tsbuildinfo']) require('node:fs').rmSync(p,{recursive:true,force:true})\""
  }
}
