{
  "name": "batpak-integrity",
  "build": {
    "dockerfile": "Dockerfile",
    "context": "..",
    "args": {
      "USER_UID": "1000",
      "USER_GID": "1000"
    }
  },
  "workspaceFolder": "/workspace/batpak",
  "remoteUser": "dev",
  "containerEnv": {
    "DEVCONTAINER": "1",
    "CARGO_TARGET_DIR": "/workspace/batpak/bpk-lib/target"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "rust-lang.rust-analyzer",
        "tamasfe.even-better-toml",
        "editorconfig.editorconfig"
      ]
    }
  },
  "postCreateCommand": "cd bpk-lib && cargo xtask doctor"
}
