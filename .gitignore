.claude/
.codex/
# Cargo build artifacts. The canonical Cargo output for this repo is
# `bpk-lib/target/`; repo-root and nested target dirs are cleanup-owned sprawl.
/target/
**/target/
# Keep bpk-lib/Cargo.lock tracked: this workspace includes binary developer
# tools, and release verification should use a reproducible dependency graph.
/.artifacts/
/.integrity-cache/
/.cache/
/guide/book/
*.profraw
*.log
/ci_output.txt
*.swp
*.swo
*~
.env
.env.local
.DS_Store
.idea/
.vscode/
# Agent IDE state. Repo-wide doctrine may live under .cursor/rules/ (tracked).
.cursor/*
!.cursor/rules/
!.cursor/rules/**
.cursor/plans/
# Local pnpm content store when install runs with a repo-local store-dir.
.pnpm-store/
# Most nested Cargo.lock files from path-dependency fixture crates are cache,
# not source of truth. The two committed fixture locks below are intentional
# downstream-package witnesses and must remain visible to staged-diff/package
# hygiene checks.
bpk-lib/crates/core/fixtures/*/Cargo.lock
!bpk-lib/crates/core/fixtures/downstream/Cargo.lock
!bpk-lib/crates/core/fixtures/kind-collision-composer/Cargo.lock
# Golden template crates are smoke-tested as standalone path-dependency apps;
# their generated lockfiles are local cache, not template source.
bpk-lib/templates/*/Cargo.lock
